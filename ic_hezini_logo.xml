<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

    <!-- Outer Glow Circle -->
    <path
        android:pathData="M50,50m-45,0a45,45 0,1 1,90 0a45,45 0,1 1,-90 0"
        android:fillAlpha="0.1">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="50"
                android:centerY="50"
                android:gradientRadius="45"
                android:type="radial">
                <item android:color="#00C2FF" android:offset="0" />
                <item android:color="#0066FF" android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Background Base Orb -->
    <path
        android:pathData="M50,50m-38,0a38,38 0,1 1,76 0a38,38 0,1 1,-76 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="30"
                android:centerY="30"
                android:gradientRadius="70"
                android:type="radial">
                <item android:color="#00C2FF" android:offset="0" />
                <item android:color="#7C3AED" android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Fluid Pulse Arc 1 -->
    <path
        android:pathData="M25,50 A25,25 0 0,1 75,50"
        android:strokeWidth="6"
        android:strokeLineCap="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="25"
                android:startY="50"
                android:endX="75"
                android:endY="50"
                android:type="linear">
                <item android:color="#FFFFFF" android:offset="0" />
                <item android:color="#00C2FF" android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Central Core -->
    <path
        android:pathData="M50,50m-12,0a12,12 0,1 1,24 0a12,12 0,1 1,-24 0"
        android:fillColor="#FFFFFF" />

</vector>
