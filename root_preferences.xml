<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="Appearance">
        <ListPreference
            app:defaultValue="system"
            app:entries="@array/theme_entries"
            app:entryValues="@array/theme_values"
            app:key="theme"
            app:title="App Theme"
            app:useSimpleSummaryProvider="true" />
    </PreferenceCategory>

    <PreferenceCategory app:title="AI Settings">
        <ListPreference
            app:defaultValue="balanced"
            app:entries="@array/style_entries"
            app:entryValues="@array/style_values"
            app:key="response_style"
            app:title="Response Style"
            app:useSimpleSummaryProvider="true" />

        <SwitchPreferenceCompat
            app:defaultValue="true"
            app:key="markdown_enabled"
            app:title="Enable Markdown"
            app:summary="Render AI responses with formatting" />
    </PreferenceCategory>

    <PreferenceCategory app:title="Notifications">
        <SwitchPreferenceCompat
            app:defaultValue="true"
            app:key="notifications_enabled"
            app:title="Push Notifications" />

        <SwitchPreferenceCompat
            app:defaultValue="true"
            app:key="daily_tip_enabled"
            app:title="Daily AI Tips" />
    </PreferenceCategory>

    <PreferenceCategory app:title="Language">
        <Preference
            app:key="language_selection"
            app:title="App Language"
            app:summary="Change the UI and AI response language" />
    </PreferenceCategory>

    <PreferenceCategory app:title="Privacy">
        <Preference
            app:key="clear_history"
            app:title="Clear Chat History"
            app:summary="Delete all your conversations locally" />
    </PreferenceCategory>

</PreferenceScreen>
