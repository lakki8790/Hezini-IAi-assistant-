<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="160"
    android:viewportHeight="160">

    <!-- Scale down the HZ logo to leave more margin -->
    <group
        android:translateX="30"
        android:translateY="35">

        <!-- Stylized H part -->
        <path
            android:pathData="M20,20 L20,80 M20,50 L50,50 M50,20 L50,80"
            android:strokeWidth="10"
            android:strokeLineCap="round"
            android:strokeLineJoin="round">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:endX="50"
                    android:endY="50"
                    android:startX="20"
                    android:startY="50"
                    android:type="linear">
                    <item android:color="#00C2FF" android:offset="0" />
                    <item android:color="#0066FF" android:offset="1" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Stylized Z part -->
        <path
            android:pathData="M60,20 L90,20 L60,80 L90,80"
            android:strokeWidth="10"
            android:strokeLineCap="round"
            android:strokeLineJoin="round">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:endX="90"
                    android:endY="50"
                    android:startX="60"
                    android:startY="50"
                    android:type="linear">
                    <item android:color="#0066FF" android:offset="0" />
                    <item android:color="#7C3AED" android:offset="1" />
                </gradient>
            </aapt:attr>
        </path>
    </group>
</vector>
