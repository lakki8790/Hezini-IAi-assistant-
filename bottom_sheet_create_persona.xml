<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/glass_card_bg"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="24dp"
                android:background="#40FFFFFF" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/create_persona"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- Avatar Selection -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Choose Avatar"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvEmojiGrid"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="12dp"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="6"
                tools:listitem="@layout/item_emoji" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUploadPhoto"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Upload photo"
                android:textSize="12sp"
                app:icon="@drawable/ic_history" />

            <!-- Avatar Background Colors -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Avatar Background"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvColorSwatches"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_color_swatch" />

            <!-- NAME -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Hezini.TextField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:hint="Persona Name"
                app:counterEnabled="true"
                app:counterMaxLength="30">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- TAGLINE -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Hezini.TextField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Tagline (e.g. Sharp strategic consultant)"
                app:counterEnabled="true"
                app:counterMaxLength="60">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTagline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- CATEGORY -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Category"
                app:boxStrokeColor="@color/hezini_cyan"
                app:hintTextColor="@color/hezini_cyan">

                <AutoCompleteTextView
                    android:id="@+id/acCategory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- SYSTEM PROMPT -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Hezini.TextField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="System Prompt"
                app:helperText="Describe how this AI should behave, its expertise and style."
                app:helperTextTextColor="@color/text_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSystemPrompt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:lines="5"
                    android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGeneratePrompt"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="Generate with AI"
                app:icon="@drawable/ic_auto_awesome"
                app:iconTint="@color/hezini_cyan" />

            <!-- PERSONALITY SLIDERS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Personality Traits"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Creativity: Precise ←→ Creative"
                android:textColor="@color/text_hint"
                android:textSize="12sp" />
            <com.google.android.material.slider.Slider
                android:id="@+id/sliderCreativity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:value="5"
                android:valueFrom="1"
                android:valueTo="10" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Formality: Casual ←→ Professional"
                android:textColor="@color/text_hint"
                android:textSize="12sp" />
            <com.google.android.material.slider.Slider
                android:id="@+id/sliderFormality"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:value="5"
                android:valueFrom="1"
                android:valueTo="10" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Detail: Brief ←→ Detailed"
                android:textColor="@color/text_hint"
                android:textSize="12sp" />
            <com.google.android.material.slider.Slider
                android:id="@+id/sliderDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:value="5"
                android:valueFrom="1"
                android:valueTo="10" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Tone: Serious ←→ Playful"
                android:textColor="@color/text_hint"
                android:textSize="12sp" />
            <com.google.android.material.slider.Slider
                android:id="@+id/sliderTone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:value="5"
                android:valueFrom="1"
                android:valueTo="10" />

            <!-- VOICE SETTINGS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Voice Settings"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Hezini.TextField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Greeting Message (Spoken on switch)"
                app:helperText="Greeting when you activate this persona"
                app:helperTextTextColor="@color/text_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etGreeting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TTS Pitch"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp" />
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderPitch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:value="1"
                        android:valueFrom="0.5"
                        android:valueTo="2.0" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TTS Speed"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp" />
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderSpeed"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:value="1"
                        android:valueFrom="0.5"
                        android:valueTo="2.0" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPreview"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Preview Persona" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                style="@style/Widget.Hezini.Button"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp"
                android:text="Save Persona" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
